FROM node:22-alpine

WORKDIR /app

# Копируем package-файлы и устанавливаем зависимости
COPY password-analyzer-frontend/package.json password-analyzer-frontend/package-lock.json ./
RUN npm ci

# Копируем исходники
COPY password-analyzer-frontend/ ./

# Vite dev-сервер
EXPOSE 3000
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
